              "condition": {
                "node_type": "Leaf",
                "label": "All-NBA First Team",
                "atom_id": "all_nba_first_team"
              },
              "if_true": {
                "node_type": "TimesConstNode",
                "label": "28% * salary_cap (All-NBA 1st)",
                "left": {
                  "node_type": "Constant",
