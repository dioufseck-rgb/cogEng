                  "constant_label": "salary_cap"
                },
                "constant_label": "higher_max_first_team_pct_28"
              },
              "if_false": {
                "node_type": "TimesConstNode",
                "label": "27% * salary_cap (All-NBA 2nd / other qualifying)",
                "left": {
                  "node_type": "Constant",
                  "label": "salary_cap",
                  "constant_label": "salary_cap"
                },
                "constant_label": "higher_max_second_team_pct_27"
              }
            }
          },
          "if_false": {
            "node_type": "TimesConstNode",
            "label": "25% * salary_cap (default <7 YOS)",
            "left": {
              "node_type": "Constant",
              "label": "salary_cap",
              "constant_label": "salary_cap"
            },
            "constant_label": "max_pct_under_7_yos_25"
          }
        },
        "if_false": {
          "node_type": "ConditionalNumericNode",
          "label": "YOS 7-9 vs 10+",
          "condition": {
